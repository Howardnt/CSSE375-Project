    "version": "0.2.0",
    "configurations": [
        {
            "type": "java",
            "name": "LinterGuiMain",
            "request": "launch",
            "mainClass": "rhit.csse.csse374.linter.presentation.gui.LinterGuiMain",
            "projectName": "LinterProject"
        },
        {
            "type": "java",
            "name": "Run Linter (Main)",
            "request": "launch",
            "mainClass": "rhit.csse.csse374.linter.presentation.Main",
            "projectName": "LinterProject",
            "args": "target/classes"
        },
        {
            "type": "java",
            "name": "Run ManualLintRunner",
            "request": "launch",
            "mainClass": "ManualLintRunner",
            "projectName": "LinterProject"
        },
        {
            "type": "java",
            "name": "Current File",
            "request": "launch",
            "mainClass": "${file}"
        }
    ]
}