@startuml
package "Presentation" as presentation {
    class LinterOutputText {
      -lines: List<String>
      +formatResult(result: LinterResult): void
      +toString(): String
    }

      class LinterGuiMain {
        +main(args: String[]): void
      }
      class LinterGuiFrame {
        -targetPathField: JTextField
        -runButton: JButton
        -progressBar: JProgressBar
        -activeWorker: RunLinterWorker
        +LinterGuiFrame()
        -onRun(): void
      }
      class RunLinterWorker {
        -projectPath: String
        +RunLinterWorker(...)
        #doInBackground(): RunResult
      }

      class CheckCatalog {
        {static} -cachedAll: List<CheckDescriptor>
        {static} +allChecks(): List<CheckDescriptor>
        -toDescriptor(...): CheckDescriptor
      }
      enum CheckCatalogCategory{
        CURSORY
        PRINCIPLE
        PATTERN
      }
      class "CheckCatalog.CheckDescriptor" as CheckDescriptor {
        +displayName: String
        +category: Category
        +defaultSelected: boolean
        +create(): LintCheck
      }
      class DefaultTargetLocator {
        {static} +findDefaultOutputDir(): String
      }
      class ResultsAccordionPanel {
        -severityFilter: JComboBox<String>
        -searchField: JTextField
        -showZeroChecks: JCheckBox
        +setGroups(groups: List<CheckGroup>): void
        -rebuild(): void
      }
      class ViolationFilter {
        {static} +SEVERITY_ALL: String
        -severity: String
        -query: String
        +ViolationFilter(severity: String, query: String)
        +apply(violations: List<Violation>): List<Violation>
        +isActive(): boolean
        -matchesSeverity(v: Violation): boolean
        -matchesQuery(v: Violation): boolean
      }
      class CollapsibleCheckPanel {
        -headerButton: JToggleButton
        -body: JPanel
        +CollapsibleCheckPanel(category: String, checkName: String, allViolations: List<Violation>, visibleViolations: List<Violation>)
        -toggle(): void
        -populateBody(violations: List<Violation>): void
      }
      class SeverityCellRenderer {
        +getTableCellRendererComponent(...): Component
      }
      class ViolationTableModel {
        -rows: List<ViolationRow>
        +setRows(newRows: List<ViolationRow>): void
        +getRowAt(rowIndex: int): ViolationRow
      }
      record ViolationRow {
        +checkName: String
        +severity: String
        +location: String
        +message: String
      }
      class "RunLinterWorker.RunResult" as RunResult {
        +result: LinterResult
      }
      class "ResultsAccordionPanel.CheckGroup" as CheckGroup {
        +category: String
        +checkName: String
        +violations: List<Violation>
      }

      class LinterCLI {
        {static} +EXIT_OK: int
        {static} +EXIT_VIOLATIONS: int
        {static} +EXIT_USAGE: int
        {static} +EXIT_ERROR: int
        -service: LinterService
        -catalogSupplier: Supplier<List<CheckDescriptor>>
        +LinterCLI()
        +LinterCLI(service: LinterService, catalogSupplier: Supplier<List<CheckDescriptor>>)
        {static} +main(args: String[]): void
        +run(args: String[], out: PrintStream, err: PrintStream): int
        -parseCategories(args: String[], err: PrintStream): Set<Category>
        -parseConfig(args: String[], err: PrintStream): LinterConfig
        -buildRequest(path: String, categories: Set<Category>, config: LinterConfig): Request
      }

      class LinterService {
        -projectLoader: Function<String, ASMProject>
        +LinterService()
        +LinterService(projectLoader: Function<String, ASMProject>)
        +run(request: Request): Response
      }

      class "LinterService.Request" as ServiceRequest {
        +projectPath: String
        +cursories: List<Cursory>
        +principles: List<Principle>
        +patterns: List<Pattern>
      }

      class "LinterService.Response" as ServiceResponse {
        +result: LinterResult
        +formattedText: String
      }

      class JsonReportWriter {
        +toJson(result: LinterResult): String
        -collectAllViolations(result: LinterResult): List<Violation>
        -appendViolation(sb: StringBuilder, v: Violation, isLast: boolean): void
      }

      class ResultsSummary {
        {static} -SEPARATOR: String
        +format(result: LinterResult, runDuration: Duration): String
        -countBySeverity(result: LinterResult): Map<SeverityLevel, Integer>
        ~formatDuration(d: Duration): String
      }
}

package domain{

Class LinterHandler{
- checks: List<LintCheck>
- project: ASMProject

+runLinterAnalysis(): LinterResult
+runChecks(checks: List<LintCheck>): List<CheckResult>
}

class ConvertToASM{
-projectLocation: String
+ConvertToASM(projectLocation: String)
+toASMProject(): ASMProject
+loadClassesFromPath(path: String): List<ClassNode>
+findAndLoadClassFiles(directory: File, classNodes: List<ClassNode>): void
+loadClassFile(classFile: File): ClassNode
}

abstract class Cursory implements LintCheck{
+run(project: ASMProject): CheckResult
+{abstract}checkClass(cls: ASMClass): List<Violation>
}

class EqualsChecker extends Cursory{
+checkClass(cls: ASMClass): List<Violation>
-checkInstruction(instruction: Instruction, method: ASMMethod): Violation
-isProblematicType(type: Type): boolean
+name(): String
}

class CamelCaseChecker extends Cursory{
    +name(): String
    +checkClass(cls: ASMClass): List<Violation>
    -checkMethodName(method: ASMMethod): Violation
    -isLowerCamelCase(name: String): Boolean
}

class PascalCaseChecker extends Cursory{
    +name(): String
    +checkClass(cls: ASMClass): List<Violation>
    -checkMethodName(method: ASMMethod): Violation
    -isPascalCase(name: String): boolean
}

class MethodTooLongPattern extends Cursory{
    -{static}MAX_PARAMETERS: int
    -{static}MAX_SOURCE_LINES: int
    -{static}MAX_BYTECODE_INSTRUCTIONS_FALLBACK: int
    +name(): String
    +checkClass(cls: ASMClass): List<Violation>
    -analyzeMethod(method: ASMMethod): List<Violation>
    -estimateLineCount(methodNode: MethodNode): int
    -countRealInstructions(methodNode: MethodNode): int
}

class InterfaceSegregationPrinciple extends Principle {
    {static} -EMPTY_METHOD_THRESHOLD: int = 2
    +name(): String
    +checkClass(cls: ASMClass): List<Violation>
    -isEmptyOrThrowsException(mn: MethodNode): boolean
}

class SrpPrinciple extends Principle {
    {static} -MIN_PUBLIC_METHODS: int = 10
    {static} -MIN_TOTAL_METHODS: int = 20
    {static} -MIN_FIELDS: int = 8
    {static} -MIN_DISJOINT_RATIO: double = 0.5
    {static} -MIN_DEPENDENCY_PACKAGES: int = 3
    -calculator: SrpMetricsCalculator

    +name(): String
    +checkClass(cls: ASMClass): List<Violation>
    -analyzeClass(classNode: ClassNode): Violation
    -computeFieldsAccessedPerMethod(classNode: ClassNode, methods: List<MethodNode>): Map<MethodNode, Set<String>>
}

class SrpMetricsCalculator {
    +computeDisjointRatio(fieldsByMethod: Map<MethodNode, Set<String>>): double
    +computeDependencyFanOut(classNode: ClassNode, methods: List<MethodNode>): int
}

class PrincipleOfLeastKnowledge extends Principle {
    +name(): String
    +checkClass(cls: ASMClass): List<Violation>
}

class PascalClassName extends Cursory{
+name(): String
+checkClass(asmClass: ASMClass): List<Violation>
-makeViolation(fullInternalName: String, simpleName: String, reason: String): Violation
-getPackageName(fullInternalName: String): String
-getSimpleClassName(fullName: String): String
-isPascalCase(name: String): boolean
-describeViolation(name: String): String
}

abstract class Principle implements LintCheck{
+run(project: ASMProject): CheckResult
+{abstract}checkClass(cls: ASMClass): List<Violation>
}

class OpenClosedPrinciple extends Principle{
-{static}METHOD_VIOLATION_THRESHOLD: int
-{static}RIGID_CLASS_THRESHOLD: int
+checkClass(cls: ASMClass): List<Violation>
-checkTypeCheckingLogic(cls: ASMClass, violations: List<Violation>)
-checkStructuralRigidity(cls: ASMClass, violations: List<Violation>)
-countTypeCheckingOpcodes(method: ASMMethod): int
+name(): String
}

class CohesionAnalyzer extends Principle{
+name(): String
+checkClass(cls: ASMClass): List<Violation>
-calculateLCOM4(asmClass: ASMClass): int
-extractMethodFieldUsage(asmClass: ASMClass, validMethods: List<String>, methodToFields: Map, methodToMethods: Map): void
-buildConnectivityGraph(validMethods: List<String>, methodToFields: Map, methodToMethods: Map): Map<String, Set<String>>
-countConnectedComponents(validMethods: List<String>, graph: Map<String, Set<String>>): int
}

class HollywoodPrinciple extends Principle{
-strategy: HollywoodStrategy
-resolvedMethodCache: Map<String, Set<String>>
+HollywoodPrinciple()
+HollywoodPrinciple(strategy: HollywoodStrategy)
+checkClass(cls: ASMClass): List<Violation>
-collectHighLevelTypes(cls: ASMClass): Set<String>
-resolveHighLevelMethods(highLevelTypes: Set<String>): Set<String>
+name(): String
}

interface HollywoodStrategy {
+analyzeCoupling(cls: ASMClass, highLevelTypes: Set<String>, highLevelMethodSignatures: Set<String>): List<Violation>
}

abstract class AbstractHollywoodMethod implements HollywoodStrategy {
    #{static}EXCLUDED_METHODS: Set<String>
    #isUpwardCall(methodInsn: MethodInsnNode, currentClassName: String, highLevelTypes: Set<String>, highLevelMethodSignatures: Set<String>): boolean
}

class StrictHollywoodStrategy extends AbstractHollywoodMethod {
+analyzeCoupling(cls: ASMClass, highLevelTypes: Set<String>, highLevelMethodSignatures: Set<String>): List<Violation>
}

class ThresholdHollywoodStrategy extends AbstractHollywoodMethod {
-threshold: int
+ThresholdHollywoodStrategy(threshold: int)
+analyzeCoupling(cls: ASMClass, highLevelTypes: Set<String>, highLevelMethodSignatures: Set<String>): List<Violation>
}

class InstantiationOnlyStrategy implements HollywoodStrategy {
-{static}EXCLUDED_METHODS: Set<String>
+analyzeCoupling(cls: ASMClass, highLevelTypes: Set<String>, highLevelMethodSignatures: Set<String>): List<Violation>
}

class HollywoodStrictPrinciple extends HollywoodPrinciple {
+HollywoodStrictPrinciple()
+name(): String
}

class HollywoodInstantiationPrinciple extends HollywoodPrinciple {
+HollywoodInstantiationPrinciple()
+name(): String
}

class HollywoodThresholdPrinciple extends HollywoodPrinciple {
+HollywoodThresholdPrinciple()
+name(): String
}

note "Wrapper classes strictly for GUI compatibility" as GuiNote
HollywoodStrictPrinciple .. GuiNote
HollywoodInstantiationPrinciple .. GuiNote
HollywoodThresholdPrinciple .. GuiNote

HollywoodPrinciple o-down-> HollywoodStrategy

abstract class Pattern implements LintCheck{
+run(project: ASMProject): CheckResult
#runPatternCheck(project: ASMProject): CheckResult
+{abstract} isPattern(cls: ASMClass): boolean
+getDetails(cls: ASMClass): String
}

class TemplatePattern extends Pattern{
-detectedPatterns: List<TemplateMethodInfo>
+TemplatePattern()
+name(): String
#runPatternCheck(project: ASMProject): CheckResult
#isPattern(cls: ASMClass): boolean
-analyzeTemplateMethod(classNode: ClassNode, method: MethodNode): TemplateMethodInfo
+getDetectedPatterns(): List<TemplateMethodInfo>
+getDetailedMessage(className: String): String
}

class TemplateMethodInfo {
    -className: String
    -templateMethodName: String
    -abstractMethodsCalled: List<String>
    +TemplateMethodInfo(className: String, templateMethodName: String)
    +addAbstractMethodCall(methodName: String): void
    +getClassName(): String
    +getTemplateMethodName(): String
    +getAbstractMethodsCalled(): List<String>
    +formatDetails(): String
}

class StrategyPattern extends Pattern{
    -{static}MIN_SWITCHES_FOR_HOTSPOT: int
    -{static}MIN_BRANCHES_FOR_HOTSPOT: int
    -{static}MIN_INSTANCEOF_FOR_HOTSPOT: int
    -{static}MIN_DISTINCT_CALL_OWNERS_SWITCH: int
    -{static}MIN_NEW_TYPES_SWITCH: int
    -{static}MIN_DISTINCT_CALL_OWNERS_BRANCH: int
    -{static}MIN_REAL_INSTRUCTIONS: int
    +name(): String
    +runPatternCheck(project: ASMProject): CheckResult
    -analyzeMethod(classNode: ClassNode, methodNode: MethodNode): Violation
    -collectMetrics(methodNode: MethodNode): Metrics
    -isIfOpcode(opcode: int): boolean
}

class DecoratorPattern extends Pattern{
    +name(): String
    #isPattern(cls: ASMClass): boolean
    -getCleanType(desc: String): String
}

class AdapterPattern extends Pattern{
+name(): String
+getDetails(asmClass: ASMClass): String
+isPattern(asmClass: ASMClass): boolean
-getRatio(asmClass: ASMClass): double
-methodUsesField(method: ASMMethod, fieldOwner: String, fieldName: String): boolean
-findPotentialAdapteeFields(asmClass: ASMClass): List<FieldNode>
-getAdapteeFieldName(asmClass: ASMClass): String
-fieldTypeMatchesInterfaces(asmClass: ASMClass, field: FieldNode): boolean
}

interface LintCheck {
+run(project: ASMProject): CheckResult
}

enum SeverityLevel {
    ERROR
    WARNING
    INFO
    -color: Color
    +getColor(): Color
    +{static}fromString(s: String): SeverityLevel
}

class Violation{
-message: String
-location: String
-severity: SeverityLevel
+Violation(message: String, location: String, severity: SeverityLevel)
+Violation(message: String, location: String, severity: String)
+Violation(message: String, location: String)
+Violation(message: String)
+getMessage(): String
+getLocation(): String
+getSeverityLevel(): SeverityLevel
+getSeverity(): String
+toString(): String
}

class CheckResult{
-violations: List<Violation>
-classesChecked: int
-methodsChecked: int
-analysisErrors: List<String>
-type: String
+CheckResult(violations: List<Violation>, classesChecked: int, methodsChecked: int, analysisErrors: List<String>, type: String)
}

class LinterResult{
-cursoryResult: List<CheckResult>
-principleResult: List<CheckResult>
-patternResult: List<CheckResult>
-totalClasses: int
-cursoryCheckCount: int
-principleCheckCount: int
-patternCheckCount: int
-projectPath: String
+hasAnyViolations(): boolean
+getTotalViolationCount(): int
+hasViolationsIn(results: List<CheckResult>): boolean
+countViolations(results: List<CheckResult>): int
}
}

package data{

class ASMClass {
-className: String
-classNode: ClassNode
-methods: List<ASMMethod>
+ASMClass(classNode: ClassNode)
+getClassName(): String
+getMethods(): List<ASMMethod>
+getClassNode(): ClassNode
+isInterface(): boolean
+isAbstract(): boolean
}

class ASMMethod {
-className: String
-methodName: String
-methodNode: MethodNode
-basicFrames: Frame<BasicValue>[]
-basicInstructions: List<Instruction>
-basicAnalysisSucceeded: boolean
-simpleFrames: Frame<BasicValue>[]
-simpleInstructions: List<Instruction>
-simpleAnalysisSucceeded: boolean
+ASMMethod(className: String, methodNode: MethodNode)
-performAnalysis(interpreter: Interpreter<BasicValue>, className: String, methodNode: MethodNode): AnalysisResult
-buildInstructions(methodNode: MethodNode, frames: Frame<BasicValue>[]): List<Instruction>
+getClassName(): String
+getMethodName(): String
+getFullMethodName(): String
+getInstructions(): List<Instruction>
+getInstructionsWithTypeInfo(): List<Instruction>
+isAnalysisSuccessful(): boolean
+isTypeInfoAvailable(): boolean
+getMethodNode(): MethodNode
+getFrames(): Frame<BasicValue>[]
+getSimpleFrames(): Frame<BasicValue>[]
}

class "ASMMethod.AnalysisResult" as AnalysisResult {
    -frames: Frame<BasicValue>[]
    -succeeded: boolean
}

class ASMProject {
-projectPath: String
-classes: List<ASMClass>
+ASMProject(projectPath: String, classNodes: List<ClassNode>)
}

class Instruction {
-instruction: AbstractInsnNode
-frame: Frame
-index: int
+Instruction(instruction: AbstractInsnNode, frame: Frame<BasicValue>, index: int)
+isReferenceComparison(): boolean
+getStackValue(positionFromTop: int): BasicValue
+getTopTwoStackValues(): StackValuePair
}

class StackValuePair {
-first: BasicValue
-second: BasicValue
+eitherIsNull(): boolean
+bothHaveType(): boolean
+getFirstType(): Type
+getSecondType(): Type
+isNullValue(): boolean
}

interface LinterConfig {
+isEnabled(checkId: String): boolean
+optionsFor(checkId: String): Map<String, String>
+{static}allEnabled(): LinterConfig
}

class MapLinterConfig implements LinterConfig {
-enabledByKey: Map<String, Boolean>
-optionsByKey: Map<String, Map<String, String>>
-defaultEnabled: boolean
+MapLinterConfig(enabledByKey: Map, optionsByKey: Map, defaultEnabled: boolean)
+isEnabled(checkId: String): boolean
+optionsFor(checkId: String): Map<String, String>
+defaultEnabled(): boolean
}

class JsonLinterConfigLoader {
+load(path: Path): LinterConfig
+read(reader: Reader): LinterConfig
+parse(json: String): LinterConfig
-parseRoot(root: JsonObject): LinterConfig
}

class "JsonLinterConfigLoader.ConfigParseException" as ConfigParseException {
+ConfigParseException(message: String)
+ConfigParseException(message: String, cause: Throwable)
}
}

LinterOutputText ..up> LinterResult

LinterHandler -down-> ASMProject
LinterHandler -right-> "*" LintCheck
LinterHandler ..> LinterResult

CheckResult --> "*" Violation
LinterResult --> "*" CheckResult
Violation --> SeverityLevel

ASMProject --> "*" ASMClass
ASMClass --> "*" ASMMethod
ASMMethod --> "*" Instruction
ASMMethod --> AnalysisResult
Instruction ..> StackValuePair
ConvertToASM ..> ASMProject

SrpPrinciple --> SrpMetricsCalculator
TemplatePattern --> "*" TemplateMethodInfo
CohesionAnalyzer ..> ASMClass

LinterGuiMain --> LinterGuiFrame
LinterGuiFrame --> CheckCatalog
LinterGuiFrame --> DefaultTargetLocator
LinterGuiFrame --> RunLinterWorker
LinterGuiFrame --> ResultsAccordionPanel
LinterGuiFrame --> JsonReportWriter
LinterGuiFrame --> ResultsSummary
LinterGuiFrame ..> LinterResult
LinterGuiFrame ..> CheckDescriptor
LinterGuiFrame ..> LinterConfig
LinterGuiFrame ..> JsonLinterConfigLoader

LinterCLI --> LinterService
LinterCLI --> CheckCatalog
LinterCLI ..> LinterResult
LinterCLI ..> LinterConfig
LinterCLI ..> JsonLinterConfigLoader
LinterCLI ..> ServiceRequest
LinterCLI ..> ServiceResponse

LinterService --> ConvertToASM
LinterService --> LinterHandler
LinterService --> LinterOutputText
LinterService ..> LinterResult
LinterService +-- ServiceRequest
LinterService +-- ServiceResponse

RunLinterWorker --> LinterService
RunLinterWorker ..> LinterResult
RunLinterWorker ..> RunResult

ResultsAccordionPanel ..> Violation
ResultsAccordionPanel ..> SeverityLevel
ResultsAccordionPanel --> ViolationFilter
ResultsAccordionPanel --> "*" CollapsibleCheckPanel
ResultsAccordionPanel --> "0..*" CheckGroup

CollapsibleCheckPanel ..> Violation

ViolationFilter ..> Violation
ViolationFilter ..> SeverityLevel

CheckCatalog ..> LintCheck
CheckCatalog --> "0..*" CheckDescriptor
CheckDescriptor ..> LintCheck
CheckCatalog ..> CheckCatalogCategory

JsonLinterConfigLoader ..> LinterConfig
JsonLinterConfigLoader ..> MapLinterConfig
JsonLinterConfigLoader +-- ConfigParseException
MapLinterConfig ..|> LinterConfig

JsonReportWriter ..> LinterResult
JsonReportWriter ..> Violation

ResultsSummary ..> LinterResult
ResultsSummary ..> SeverityLevel
ResultsSummary ..> Violation

SeverityCellRenderer ..> SeverityLevel
ViolationTableModel --> "*" ViolationRow

@enduml
