@startuml
'
' Hand-authored architecture skeleton (kept intentionally high-level).
' Layers flow left-to-right: Presentation → Domain → Data.
'

left to right direction

skinparam linetype ortho
skinparam nodesep 45
skinparam ranksep 45
skinparam packageStyle rectangle
skinparam shadowing false
skinparam classAttributeIconSize 0

package "Presentation" as presentation {
  together {
    class Main {
      +main(args: String[]): void
    }
    class LinterOutputText {
      -lines: List<String>
      +formatResult(result: LinterResult): void
      +toString(): String
    }
  }

  package "GUI" as gui {
    together {
      class LinterGuiMain {
        +main(args: String[]): void
      }
      class LinterGuiFrame {
        -targetPathField: JTextField
        -runButton: JButton
        -progressBar: JProgressBar
        -activeWorker: RunLinterWorker
        +LinterGuiFrame()
        -onRun(): void
      }
      class RunLinterWorker {
        -projectPath: String
        +RunLinterWorker(...)
        #doInBackground(): RunResult
      }
    }

    together {
      class CheckCatalog {
        {static} -cachedAll: List<CheckDescriptor>
        {static} +allChecks(): List<CheckDescriptor>
      }
      enum "CheckCatalog.Category" as Category {
        CURSORY
        PRINCIPLE
        PATTERN
      }
      class "CheckCatalog.CheckDescriptor" as CheckDescriptor {
        +displayName: String
        +category: Category
        +defaultSelected: boolean
        +create(): LintCheck
      }
      class DefaultTargetLocator {
        {static} +findDefaultOutputDir(): String
      }
      class ResultsAccordionPanel {
        +setGroups(groups: List<CheckGroup>): void
      }
      class "RunLinterWorker.RunResult" as RunResult {
        +result: LinterResult
      }
      class "ResultsAccordionPanel.CheckGroup" as CheckGroup {
        +checkName: String
        +violations: List<Violation>
      }
    }
  }
}

package "Domain" as domain {
  together {
    class ConvertToASM {
      -projectLocation: String
      +toASMProject(): ASMProject
    }
    class LinterHandler {
      -project: ASMProject
      +runLinterAnalysis(): LinterResult
    }
  }

  together {
    interface LintCheck {
      +name(): String
      +run(project: ASMProject): CheckResult
    }
    abstract class Cursory {
      +{abstract} checkClass(cls: ASMClass): List<Violation>
    }
    abstract class Principle {
      +{abstract} checkClass(cls: ASMClass): List<Violation>
    }
    abstract class Pattern {
      #runPatternCheck(project: ASMProject): CheckResult
      +{abstract} isPattern(cls: ASMClass): boolean
    }
  }

  together {
    class LinterResult {
      -totalClasses: int
      -projectPath: String
      +getTotalClasses(): int
      +getProjectPath(): String
      +getTotalViolationCount(): int
    }
    class CheckResult {
      -violations: List<Violation>
      -type: String
      +hasViolations(): boolean
      +getViolations(): List<Violation>
      +toString(): String
    }
    class Violation {
      -message: String
      -location: String
      -severity: String
      +getMessage(): String
      +getSeverity(): String
    }
  }

  together {
    class HollywoodPrinciple
    interface HollywoodStrategy
    class ThresholdHollywoodStrategy
    class StrictHollywoodStrategy
    class InstantiationOnlyStrategy

    class HollywoodStrictPrinciple
    class HollywoodInstantiationPrinciple
    class HollywoodThresholdPrinciple
  }

  note "Wrapper classes strictly for GUI compatibility" as GuiNote
  HollywoodStrictPrinciple .. GuiNote
  HollywoodInstantiationPrinciple .. GuiNote
  HollywoodThresholdPrinciple .. GuiNote
}

package "Data" as data {
  together {
    class ASMProject {
      -projectPath: String
      -classes: List<ASMClass>
      +getProjectPath(): String
      +getClasses(): List<ASMClass>
    }
    class ASMClass {
      -className: String
      +getClassName(): String
      +getMethods(): List<ASMMethod>
    }
    class ASMMethod {
      -methodName: String
      +getInstructions(): List<Instruction>
      +getInstructionsWithTypeInfo(): List<Instruction>
      +isTypeInfoAvailable(): boolean
    }
  }

  together {
    class Instruction {
      -index: int
      +isReferenceComparison(): boolean
      +getTopTwoStackValues(): StackValuePair
    }
    class StackValuePair {
      +eitherIsNull(): boolean
      +bothHaveType(): boolean
    }
  }
}

' Layer ordering hints (keeps packages aligned as columns)
presentation -[hidden]-> domain
domain -[hidden]-> data

' Presentation → Domain
Main --> ConvertToASM
Main --> LinterHandler
Main --> LinterOutputText
LinterOutputText ..> LinterResult

' GUI wiring (Presentation)
LinterGuiMain --> LinterGuiFrame
LinterGuiFrame --> CheckCatalog
LinterGuiFrame --> DefaultTargetLocator
LinterGuiFrame --> RunLinterWorker
LinterGuiFrame --> ResultsAccordionPanel
LinterGuiFrame ..> LinterResult
LinterGuiFrame ..> CheckDescriptor

RunLinterWorker --> ConvertToASM
RunLinterWorker --> LinterHandler
RunLinterWorker --> LinterOutputText
RunLinterWorker ..> LinterResult
RunLinterWorker ..> RunResult

ResultsAccordionPanel ..> Violation
ResultsAccordionPanel *--> "0..*" CheckGroup
CheckCatalog ..> LintCheck
CheckCatalog *--> "0..*" CheckDescriptor
CheckDescriptor ..> LintCheck

' Domain internals
ConvertToASM --> ASMProject
LinterHandler --> ASMProject
LinterHandler --> "0..*" LintCheck
LinterHandler ..> LinterResult

Cursory ..|> LintCheck
Principle ..|> LintCheck
Pattern ..|> LintCheck

HollywoodPrinciple --|> Principle
HollywoodPrinciple o--> HollywoodStrategy
ThresholdHollywoodStrategy ..|> HollywoodStrategy
StrictHollywoodStrategy ..|> HollywoodStrategy
InstantiationOnlyStrategy ..|> HollywoodStrategy

HollywoodStrictPrinciple --|> HollywoodPrinciple
HollywoodInstantiationPrinciple --|> HollywoodPrinciple
HollywoodThresholdPrinciple --|> HollywoodPrinciple

LinterResult *--> "0..*" CheckResult
CheckResult *--> "0..*" Violation

' Data internals
ASMProject *--> "0..*" ASMClass
ASMClass *--> "0..*" ASMMethod
ASMMethod *--> "0..*" Instruction
Instruction ..> StackValuePair
ConvertToASM ..> ASMProject

@enduml